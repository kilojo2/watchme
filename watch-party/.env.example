# =============================================================================
# WatchMe — Environment Variables (Railway / Deployment)
# =============================================================================
# Copy this file to .env and fill in your Firebase project credentials.
#
#   cp .env.example .env
#
# These variables are REQUIRED for the app to connect to Firebase.
# All variables prefixed with VITE_ are exposed to the client-side code.
#
# =============================================================================
# Firebase Configuration
# =============================================================================
# Get these from: Firebase Console → Project Settings → Web App
# Or create a new web app in your Firebase project.

# 🔑 API Key
VITE_FIREBASE_API_KEY=your-api-key-here

# 🌐 Auth Domain (usually <project-id>.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# 🗄️ Realtime Database URL (from Firebase → Realtime Database)
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.region.firebasedatabase.app

# 🆔 Project ID
VITE_FIREBASE_PROJECT_ID=your-project-id

# 📦 Storage Bucket (optional, for future use)
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# 📧 Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012

# 🆔 App ID
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# =============================================================================
# Railway-specific (optional, set automatically by Railway)
# =============================================================================
# RAILWAY_ENVIRONMENT=production
# RAILWAY_SERVICE_NAME=watchme
# RAILWAY_PROJECT_ID=abc-123
# RAILWAY_PROJECT_NAME=watchme
