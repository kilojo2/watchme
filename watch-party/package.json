{
  "name": "watch-party",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:railway": "vite build --mode production",
    "build:win": "vite build && electron-builder build --win",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "vite"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.1",
    "cross-fetch": "^4.1.0",
    "firebase": "^12.16.0",
    "hls.js": "^1.6.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "react-youtube": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^31.6.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "build": {
    "appId": "com.watchparty.electron",
    "productName": "WatchParty",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/@ghostery/**/*",
      "node_modules/cross-fetch/**/*",
      "node_modules/tldts-experimental/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "WatchParty-${version}-portable.exe"
    },
    "extraMetadata": {
      "main": "dist-electron/main.mjs"
    }
  }
}
